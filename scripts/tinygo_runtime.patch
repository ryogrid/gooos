diff --git a/src/runtime/interrupt/interrupt_gooos.go b/src/runtime/interrupt/interrupt_gooos.go
new file mode 100644
index 0000000..cedf80b
--- /dev/null
+++ b/src/runtime/interrupt/interrupt_gooos.go
@@ -0,0 +1,33 @@
+//go:build gooos && baremetal && kernelspace
+
+package interrupt
+
+//go:linkname gooos_readFlags readFlags
+func gooos_readFlags() uintptr
+
+//go:linkname gooos_restoreFlags restoreFlags
+func gooos_restoreFlags(flags uintptr)
+
+//go:linkname gooos_cli cli
+func gooos_cli()
+
+// State holds RFLAGS at the moment of Disable() so Restore() can
+// decide whether to re-enable interrupts.
+type State uintptr
+
+func Disable() State {
+	flags := gooos_readFlags()
+	gooos_cli()
+	return State(flags)
+}
+
+func Restore(state State) { gooos_restoreFlags(uintptr(state)) }
+
+// In always returns false on gooos. The TinyGo runtime uses In()
+// to prevent heap allocation and task.Pause() in ISR context. On
+// gooos, syscall handlers (which run in ISR context via int 0x80)
+// ARE allowed to block on channels and allocate — this is the
+// fundamental design: each Ring-3 process is a goroutine that
+// blocks mid-ISR during syscalls. The ISR depth counter is
+// managed by processExit for the sys_exit path.
+func In() bool { return false }
