@@ -0,0 +1,13 @@
+//go:build gooos && baremetal && !kernelspace
+
+// Userspace has no IRQs; Disable / Restore / In are trivial no-ops.
+// This file exists only so code under the (gooos && baremetal) tag
+// combo (runtime.addTimer, scheduler internals) resolves the
+// interrupt.* symbols at link time.
+
+package interrupt
+
+type State uintptr
+
+func Disable() State      { return 0 }
+func Restore(state State) {}
+func In() bool            { return false }
