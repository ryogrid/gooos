diff --git a/src/runtime/runtime_gooos.go b/src/runtime/runtime_gooos.go
new file mode 100644
index 00000000..3cadea13
--- /dev/null
+++ b/src/runtime/runtime_gooos.go
@@ -0,0 +1,273 @@
+//go:build gooos && baremetal && kernelspace
+
+// gooos-local runtime bodies for bare-metal x86_64 Ring 0.
+// Replaces the parts of runtime_unix.go incompatible with kernel
+// mode. The kernel defines putchar, pitTicks, and the cli/sti/hlt
+// primitives these stubs rely on.
+
+package runtime
+
+// timeUnit is defined in upstream runtime.go since TinyGo 0.40.x;
+// no longer redeclared here.
+
+// TinyGo 0.40.x disallows //go:linkname on variable declarations (it
+// creates a local symbol that collides with the kernel's definition).
+// Use //go:extern, which marks the variable as "allocated elsewhere"
+// so the compiler emits only a reference.
+//
+//go:extern main.pitTicks
+var gooos_pitTicks uint64
+
+// The kernel's assembly stubs in src/stubs.S use unqualified names
+// (no package prefix), so we link directly to those symbols.
+
+//go:linkname gooos_cli cli
+func gooos_cli()
+
+//go:linkname gooos_sti sti
+func gooos_sti()
+
+//go:linkname gooos_hlt hlt
+func gooos_hlt()
+
+// sleepTicks idles on the PIT counter until `d` ticks have elapsed.
+// The kernel's timer ISR increments gooos_pitTicks at 100 Hz.
+func sleepTicks(d timeUnit) {
+	deadline := gooos_pitTicks + uint64(d)
+	for gooos_pitTicks < deadline {
+		gooos_sti()
+		gooos_hlt()
+		gooos_cli()
+	}
+}
+
+func ticks() timeUnit { return timeUnit(gooos_pitTicks) }
+
+// 100 Hz PIT: one tick = 10 ms = 10_000_000 ns.
+func ticksToNanoseconds(t timeUnit) int64  { return int64(t) * 10_000_000 }
+func nanosecondsToTicks(ns int64) timeUnit { return timeUnit(ns / 10_000_000) }
+
+// tinygo_register_fatal_signals is provided by src/stubs.S (the
+// kernel has had this stub since before goroutine support). No Go
+// body needed here.
+
+// putchar writes a single byte to COM1. Used by runtime.printstring.
+//
+//go:linkname gooos_outb outb
+func gooos_outb(port uint16, value uint8)
+
+func putchar(c byte) { gooos_outb(0x3F8, c) }
+
+// buffered is a no-op on bare metal — no line-buffered stdio.
+func buffered() int { return 0 }
+
+// getchar is not used by gooos; return 0 to avoid pulling in stdin.
+func getchar() byte { return 0 }
+
+// exit / abort: kernel panic paths. No process to exit; halt forever.
+func exit(code int) {
+	for {
+		gooos_hlt()
+	}
+}
+
+func abort() {
+	for {
+		gooos_hlt()
+	}
+}
+
+// preinit is called by the runtime before initAll(). gooos's main.go
+// performs all hardware init in user main(), so preinit is a no-op.
+func preinit() {}
+
+// main is the C-ABI entry point called from boot.S after the
+// 32->64-bit bootstrap. run() initializes the heap, runs package
+// init functions, and invokes the user-written main in main.go.
+// If run() returns, halt forever.
+//
+//export main
+func main() {
+	preinit()
+	run()
+	exit(0)
+}
+
+// waitForEvents provided by wait_other.go (fallback). No override
+// needed — that fallback body is a no-op, acceptable here.
+
+// ---- M3: scheduler=cores Wave 2 declarations ---------------------
+//
+// Under scheduler=cores, upstream scheduler_cores.go:260-290 defines
+// lockFutex/unlockFutex/lockAtomics/unlockAtomics/lockScheduler/
+// unlockScheduler which take Lock()/Unlock() methods on four package-
+// level lock variables. Upstream targets (RP2040/RP2350) provide
+// these in runtime_rp2.go:295-298 as a target-local spinLock type.
+// gooos mirrors that pattern here.
+//
+// DO NOT redefine the lockX/unlockX functions — upstream already
+// does. Only the variables are supplied here.
+
+// numCPU is the compile-time upper bound on core count. Matches
+// gooos's maxCPUs (1 BSP + 16 APs = 17). Used by upstream
+// scheduler_cores.go's `cpuTasks [numCPU]*task.Task` and
+// `systemStack [numCPU]uintptr` arrays.
+const numCPU = 17
+
+//go:linkname gooos_spinlockAcquire spinlockAcquire
+//go:noescape
+func gooos_spinlockAcquire(lock *uint32)
+
+//go:linkname gooos_spinlockRelease spinlockRelease
+//go:noescape
+func gooos_spinlockRelease(lock *uint32)
+
+// gooosSpinLock is the lock type consumed by the upstream
+// lockFutex/lockAtomics/lockScheduler helpers.
+type gooosSpinLock struct {
+	locked uint32
+}
+
+//go:nosplit
+func (l *gooosSpinLock) Lock() { gooos_spinlockAcquire(&l.locked) }
+
+//go:nosplit
+func (l *gooosSpinLock) Unlock() { gooos_spinlockRelease(&l.locked) }
+
+var (
+	printLock     gooosSpinLock
+	schedulerLock gooosSpinLock
+	atomicsLock   gooosSpinLock
+	futexLock     gooosSpinLock
+)
+
+// M5.1: currentCPU + currentTask references moved to
+// runtime_gooos_sched_cores.go (gated by !scheduler.none) so this
+// file compiles under scheduler=none too.
+
+// gcPauseCore is called by gc_stack_cores.go's gcMarkReachable
+// to stop every peer core before scanning. M3 stub: returns
+// immediately. M5 replaces with IPI + per-CPU ack-flag spin.
+// Acceptable at M3 because the gooos test matrix does not
+// exercise heavy concurrent allocation during GC.
+//
+//go:linkname gcPauseCore runtime.gcPauseCore
+//go:nosplit
+func gcPauseCore(cpu uint32) { /* M3 stub; full impl at M5 */ }
+
+// gcResumeCore mirror of gcPauseCore for symmetry with the
+// gc_stack_cores.go protocol.
+//
+//go:linkname gcResumeCore runtime.gcResumeCore
+//go:nosplit
+func gcResumeCore(cpu uint32) { /* M3 stub; full impl at M5 */ }
+
+// ---- Multicore-scheduler target primitives (RP2-style) -----------
+//
+// Upstream scheduler_cores.go + gc_stack_cores.go reference a set
+// of target-local primitives — RP2 provides them via arm.Asm("wfe")
+// / arm.Asm("sev"). The gooos equivalent uses hlt (already a no-op
+// on no-events) and the existing IPI path (gooosWakeupCPU) for
+// cross-CPU nudges. Most are no-ops at M3 because gooos's BSP-
+// driven scheduling already handles the coordination the RP2
+// multicore scheduler needed. Future M3-6 / M5 may revisit.
+
+//go:nosplit
+func spinLoopWait() {
+	// Wait for the next interrupt-triggered wake event. gooos's hlt
+	// semantics match RP2's wfe for this purpose: halt until the
+	// next IPI/LAPIC-timer wake.
+	gooos_sti()
+	gooos_hlt()
+	gooos_cli()
+}
+
