+// stealWork attempts to steal a task from another CPU's runqueue.
+// Round-robin scan starting from the CPU after the current one.
+// Returns nil if no work is available on any other CPU.
+func stealWork() *task.Task {
+	me := gooosCpuID()
+	for i := uint32(1); i < gooosSMPMaxCPUs; i++ {
+		peer := (me + i) % gooosSMPMaxCPUs
+		t := runqueues[peer].Pop()
+		if t != nil {
+			return t
+		}
+	}
+	return nil
+}
