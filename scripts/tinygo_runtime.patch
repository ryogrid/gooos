diff --git a/src/runtime/interrupt/interrupt_gooos.go b/src/runtime/interrupt/interrupt_gooos.go
new file mode 100644
index 00000000..e7837ff6
--- /dev/null
+++ b/src/runtime/interrupt/interrupt_gooos.go
@@ -0,0 +1,47 @@
+//go:build gooos && baremetal && kernelspace
+
+package interrupt
+
+//go:linkname gooos_readFlags readFlags
+func gooos_readFlags() uintptr
+
+//go:linkname gooos_restoreFlags restoreFlags
+func gooos_restoreFlags(flags uintptr)
+
+//go:linkname gooos_cli cli
+func gooos_cli()
+
+// State holds RFLAGS at the moment of Disable() so Restore() can
+// decide whether to re-enable interrupts.
+type State uintptr
+
+func Disable() State {
+	flags := gooos_readFlags()
+	gooos_cli()
+	return State(flags)
+}
+
+func Restore(state State) { gooos_restoreFlags(uintptr(state)) }
+
+// In returns true when the CPU is inside a real ISR (not a syscall
+// handler). Per M2 (impldoc/smp_m2_ap_lapic_timer.md): the ISR
+// prologue bumps per-CPU %gs:4 on every vector and additionally
+// bumps per-CPU %gs:44 when the vector is 0x80 (syscall). This
+// function returns true only when depth > 0 AND syscall-depth == 0,
+// so TinyGo's task.Pause() is still allowed during blocking syscalls
+// (Ring-3 processes are goroutines that block mid-ISR during
+// int 0x80 handlers — the fundamental gooos syscall design).
+// Real IRQs (timer, keyboard, e1000, etc.) still correctly return
+// true, so the runtime's "no heap alloc in interrupt" / "no
+// task.Pause in interrupt" invariants hold for those paths.
+
+//go:linkname gooos_readInterruptDepth readInterruptDepth
+func gooos_readInterruptDepth() uint32
+
+//go:linkname gooos_readSyscallDepth readSyscallDepth
+func gooos_readSyscallDepth() uint32
+
+//go:nosplit
+func In() bool {
+	return gooos_readInterruptDepth() != 0 && gooos_readSyscallDepth() == 0
+}
