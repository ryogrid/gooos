{
  "llvm-target": "x86_64-unknown-none-elf",
  "cpu": "x86-64",
  "features": "-mmx,-sse,-sse2,-sse3,-ssse3,-sse4.1,-sse4.2,-avx,-avx2,-avx512f",
  "build-tags": ["gooos", "baremetal"],
  "goos": "linux",
  "goarch": "amd64",
  "gc": "leaking",
  "scheduler": "tasks",
  "panic-strategy": "trap",
  "linker": "ld.lld",
  "rtlib": "compiler-rt",
  "default-stack-size": 8192,
  "automatic-stack-size": true
}
